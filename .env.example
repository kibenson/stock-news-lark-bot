# ===========================
# Lark / 飞书 配置
# ===========================
# Webhook Token (从飞书自定义机器人设置中获取)
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token-here
# 多个Webhook，用逗号分隔 (可选)
# LARK_WEBHOOK_URLS=url1,url2,url3

# ===========================
# AI 配置 (千问/Qwen)
# ===========================
# DashScope API Key (https://dashscope.aliyuncs.com)
DASHSCOPE_API_KEY=your-dashscope-api-key
# 使用的模型: qwen-max, qwen-plus, qwen-turbo
AI_MODEL=qwen-plus
# DashScope OpenAI兼容模式 Endpoint
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===========================
# 新闻 API 密钥
# ===========================
NEWS_API_KEY=your-newsapi-key
FINNHUB_API_KEY=your-finnhub-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ===========================
# 数据库配置
# ===========================
# SQLite (默认)
DATABASE_URL=sqlite:///./stock_news.db
# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:password@localhost:5432/stock_news

# ===========================
# 定时任务配置
# ===========================
# 每天推送时间 (24小时制)
PUSH_SCHEDULE_HOUR=8
PUSH_SCHEDULE_MINUTE=0
# 时区
PUSH_TIMEZONE=Asia/Shanghai

# ===========================
# 应用配置
# ===========================
APP_HOST=0.0.0.0
APP_PORT=8000
# 用于加密的密钥（请修改为随机字符串）
SECRET_KEY=your-secret-key-change-this-in-production
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# 是否启用调试模式
DEBUG=false
